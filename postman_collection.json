{
  "info": {
    "name": "Weather App API",
    "description": "Complete API collection for Weather App - Authentication, Weather, Forecast, and Favorites",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Felix\",\n  \"email\": \"felix@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"felix@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Weather",
      "item": [
        {
          "name": "Get Current Weather",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/weather/London",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "weather", "London"]
            }
          }
        },
        {
          "name": "Get 5-Day Forecast",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/forecast/London",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "forecast", "London"]
            }
          }
        }
      ]
    },
    {
      "name": "Favorites",
      "item": [
        {
          "name": "Add Favorite City",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"London\""
            },
            "url": {
              "raw": "http://localhost:8080/api/favorites",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "favorites"]
            }
          }
        },
        {
          "name": "Get All Favorites",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/favorites",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "favorites"]
            }
          }
        },
        {
          "name": "Remove Favorite City",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/favorites/London",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "favorites", "London"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token from login response"
    }
  ]
}